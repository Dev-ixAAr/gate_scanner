<?xml version="1.0" encoding="utf-8"?>
<!--
    Production network security: HTTPS only (cleartext disabled by default).
    Debug manifest overlay references network_security_config_debug.xml.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
